  "remediation_procedures": {
    "manual_game_status_update": {
      "when_to_use": "Game at halftime but database not updated",
      "steps": [
        "1. Find game ID:",
        "   SELECT id, home_team, away_team FROM games WHERE home_team = 'PHX'",
        "2. Update game status:",
        "   UPDATE games SET game_status = 'Halftime', period = 2, clock = '0:00' WHERE id = <id>",
        "3. Verify update:",
        "   SELECT game_status, period, clock FROM games WHERE id = <id>",
        "4. Wait 10 seconds for trigger",
        "5. Check if prediction created"
      ],
      "automation": "Can be done via Python script"
    },
    
    "restart_automation": {
      "when_to_use": "Automation not responding, crashed, or stuck",
      "steps": [
        "1. Graceful stop: kill -15 $(cat .perrypicks.pid)",
        "2. Wait 5 seconds",
        "3. Force kill if needed: kill -9 $(cat .perrypicks.pid)",
        "4. Start: python start.py",
        "5. Wait 10 seconds",
        "6. Verify: ps -p $(cat .perrypicks.pid)"
      ],
      "script": "./stop_with_watchdog.sh && ./start_with_watchdog.sh"
    },
    
    "restart_watchdog": {
      "when_to_use": "Watchdog not working, needs update",
      "steps": [
        "1. Stop: kill -15 $(cat .watchdog.pid)",
        "2. Remove PID file: rm .watchdog.pid",
        "3. Start: python watchdog.py",
        "4. Verify: ps -p $(cat .watchdog.pid)"
      ]
    },
    
    "check_prediction_status": {
      "when_to_use": "Need to see if prediction was created/posted",
      "steps": [
        "1. Check recent predictions:",
        "   SELECT p.id, g.home_team, g.away_team, p.trigger_type, p.status, p.posted_to_discord, p.created_at",
        "   FROM predictions p JOIN games g ON p.game_id = g.id",
        "   WHERE p.created_at > datetime('now', '-1 hour')",
        "   ORDER BY p.created_at DESC",
        "2. Check status: 'pending' = created, 'posted' = success, 'failed' = error",
        "3. Check posted_to_discord: True = sent, False = not sent"
      ]
    },
    
    "test_discord_webhook": {
      "when_to_use": "Discord not receiving predictions",
      "steps": [
        "1. Get webhook URL from .env",
        "2. Test manually:",
        "   curl -X POST -H 'Content-Type: application/json' -d '{\"content\": \"Test from Perry\"}' <WEBHOOK_URL>",
        "3. Check Discord for message",
        "4. If error: update webhook URL"
      ]
    }
  },
  
  "database_queries": {
    "get_todays_games": {
      "query": "SELECT * FROM games WHERE DATE(game_date) = DATE('now')",
      "purpose": "Get all games scheduled for today"
    },
    
    "get_games_at_halftime": {
      "query": "SELECT * FROM games WHERE game_status = 'Halftime' OR (period = 2 AND game_status LIKE '%Halftime%')",
      "purpose": "Find games currently at halftime"
    },
    
    "get_recent_predictions": {
      "query": "SELECT * FROM predictions WHERE created_at > datetime('now', '-1 hour') ORDER BY created_at DESC",
      "purpose": "Get predictions created in last hour"
    },
    
    "get_stale_predictions": {
      "query": "SELECT * FROM predictions WHERE created_at < datetime('now', '-4 hours') AND posted_to_discord = 0",
      "purpose": "Find predictions that were never posted (watchdog check)"
    },
    
    "get_games_not_updating": {
      "query": "SELECT * FROM games WHERE DATE(game_date) = DATE('now') AND (updated_at IS NULL OR updated_at < datetime('now', '-5 minutes')) AND game_status NOT IN ('Final', 'Scheduled')",
      "purpose": "Find games not being updated (API failure detection)"
    }
  },
  
