{
  "meta": {
    "version": "1.2.0",
    "created": "2026-02-26",
    "author": "Perry (code-puppy-724a09)",
    "purpose": "Persistent context library for PerryPicks system - use this FIRST when encountering any issue",
    "last_updated": "2026-02-27"
  },
  
  "system_overview": {
    "name": "PerryPicks v4",
    "purpose": "Automated NBA halftime prediction system using Reptar ML model",
    "architecture": [
      "Automation Service (start.py) - Main daemon",
      "Game State Monitor - Polls NBA CDN for live games",
      "Trigger Engine - Detects halftime, Q3 5min events",
      "Prediction Generator - Creates betting recommendations",
      "Discord Bot - Posts predictions to Discord",
      "Health Watchdog (watchdog.py) - Monitors all components",
      "Dashboard API - Web interface",
      "Odds API - Fetches live betting odds"
    ],
    "data_flow": [
      "1. Schedule fetched from ESPN/NBA CDN",
      "2. Games stored in SQLite database",
      "3. Game State Monitor polls NBA CDN every 30s",
      "4. When game reaches halftime/Q3-5min, trigger fires",
      "5. Prediction generated using Reptar model",
      "6. Live odds fetched from bookmakers",
      "7. Recommendations created (spread, total, ML props)",
      "8. Prediction posted to Discord"
    ]
  },
  
  "critical_files": {
    "main_automation": {
      "path": "start.py",
      "purpose": "Main automation daemon entry point",
      "key_functions": [
        "_update_game_statuses() - Updates game status from ESPN",
        "_check_and_queue_games() - Re-queues games on date change",
        "_run_halftime_trigger() - Processes halftime events",
        "_run_q3_5min_trigger() - Processes Q3 5min events"
      ],
      "important": "This is the main process that must be running"
    },
    "watchdog": {
      "path": "watchdog.py",
      "purpose": "Health monitoring daemon",
      "key_functions": [
        "_check_automation() - Checks if main process running",
        "_check_backend() - Backend API health",
        "_check_odds_api() - Odds API health",
        "_check_database() - Database connectivity",
        "_check_stuck_states() - Stale predictions, API failures",
        "_restart_automation() - Restarts main process"
      ],
      "important": "Runs independently, can restart automation"
    },
    "database": {
      "path": "dashboard/backend/database.py",
      "purpose": "SQLAlchemy ORM models and session management",
      "tables": ["games", "predictions", "ghost_bets", "bankrolls", "system_stats", "prediction_bets", "parlays", "alerts"]
    },
    "game_state_monitor": {
      "path": "src/automation/game_state.py",
      "purpose": "Polls NBA CDN for live game updates",
      "key_functions": [
        "update_all_games() - Updates all tracked games",
        "get_live_games() - Gets currently live games"
      ],
      "important": "Uses NBA CDN boxscore endpoints"
    },
    "prediction_generator": {
      "path": "src/discord_bot/prediction_generator.py",
      "purpose": "Creates betting recommendations",
      "key_functions": [
        "generate_halftime_post() - Generates halftime predictions",
        "_calculate_edge() - Calculates betting edge",
        "_confidence_tier() - Determines confidence grade"
      ],
      "important": "Implements odds retry logic, team matching"
    },
    "discord_bot": {
      "path": "src/discord_bot/discord_bot.py",
      "purpose": "Posts predictions to Discord",
      "key_functions": [
        "send_discord_message() - Sends messages via webhook"
      ],
      "important": "Uses DISCORD_WEBHOOK_URL env var"
    },
    "schedule": {
      "path": "src/schedule.py",
      "purpose": "Fetches game schedules from ESPN/NBA CDN",
      "key_functions": [
        "fetch_schedule() - Main schedule fetch function",
        "get_nba_ids() - Gets NBA IDs for games"
      ],
      "important": "Handles team name/tricode normalization"
    }
  },
  
  "database_schema": {
    "games": {
      "primary_key": "id",
      "important_fields": [
        "id - Internal ID",
        "nba_id - NBA game ID (0022500855)",
        "home_team - Tricode (PHX, LAL)",
        "away_team - Tricode (LAL, PHX)",
        "game_status - Scheduled, In Progress, Halftime, Final",
        "period - Current quarter (1-4, 5+ for OT)",
        "clock - Game clock (e.g., '7:42')",
        "updated_at - When game was last updated"
      ],
      "critical": "Trigger checks game_status, period, clock"
    },
    "predictions": {
      "primary_key": "id",
      "important_fields": [
        "id - Prediction ID",
        "game_id - Foreign key to games table",
        "trigger_type - pregame, halftime, q3_5min",
        "status - pending, posted, failed, correct, wrong",
        "posted_to_discord - Boolean",
        "created_at - Timestamp"
      ],
      "critical": "Watchdog checks for stale (>4h old, not posted)"
    },
    "ghost_bets": {
      "primary_key": "id",
      "important_fields": [
        "id - Bet ID",
        "game_id - Foreign key",
        "bet_type - total, spread, moneyline, team_total",
        "result - pending, won, lost, push",
        "actual_payout - $ amount won/lost"
      ]
    }
  },
  
  "environment_variables": {
    "DISCORD_WEBHOOK_URL": {
      "purpose": "Discord webhook for predictions",
      "required": true,
      "fallback": "DISCORD_ALERTS_WEBHOOK"
    },
    "DISCORD_ALERTS_WEBHOOK": {
      "purpose": "Discord webhook for watchdog alerts",
      "required": false,
      "notes": "If not set, uses DISCORD_WEBHOOK_URL"
    },
    "USE_LOCAL_ODDS_API": {
      "purpose": "Use local odds API service",
      "required": false,
      "default": "false",
      "values": ["true", "false"]
    },
    "DATABASE_URL": {
      "purpose": "SQLite database path",
      "required": false,
      "default": "sqlite:///dashboard/backend/perrypicks.db"
    }
  },
  
  "common_errors": {
    "game_not_updating": {
      "symptoms": [
        "Game at halftime but no prediction posted",
        "Database shows 'Scheduled' when game is live",
        "Logs show '403 Forbidden' from NBA CDN",
        "Logs show 'timeout' from ESPN"
      ],
      "root_cause": [
        "NBA CDN rate limiting (403 Forbidden)",
        "ESPN API connectivity issues (timeout)",
        "Network issues"
      ],
      "detection": "Watchdog: 'X games not updating (API failure)'",
      "immediate_fix": [
        "Option 1: Manually update game status in database",
        "Option 2: Wait for APIs to recover",
        "Option 3: Restart automation"
      ],
      "manual_update_sql": [
        "UPDATE games",
        "SET game_status = 'Halftime', period = 2, clock = '0:00', updated_at = datetime('now')",
        "WHERE id = <game_id>"
      ],
      "long_term_fix": [
        "Reduce NBA CDN polling frequency",
        "Add retry logic with exponential backoff",
        "Use ESPN as fallback for live data"
      ]
    },
    
    "trigger_not_firing": {
      "symptoms": [
        "Game at halftime but no prediction created",
        "Trigger logic should have fired but didn't",
        "Game status updated correctly but no prediction"
      ],
      "root_cause": [
        "Trigger not checking correct status value",
        "Trigger not being called at all",
        "Trigger disabled in configuration",
        "Bug in trigger logic"
      ],
      "detection": "Watchdog can't detect this (logic bug)",
      "troubleshooting_steps": [
        "1. Check trigger configuration in start.py",
        "2. Check if trigger is enabled",
        "3. Check game status in database",
        "4. Check logs for trigger activity",
        "5. Manually trigger prediction to test"
      ],
      "manual_trigger": [
        "Call prediction generation directly:",
        "python3 -c 'from src.discord_bot.prediction_generator import generate_halftime_post; generate_halftime_post(<game_id>)'"
      ]
    },
    
    "odds_fetch_failure": {
      "symptoms": [
        "Prediction created but has no odds",
        "Bets show 'Odds: N/A'",
        "Logs show timeout or connection errors from odds API"
      ],
      "root_cause": [
        "Odds API not responding",
        "Bookmaker API rate limiting",
        "Network issues",
        "Invalid game ID"
      ],
      "detection": "Watchdog can't detect (HTTP 200 OK, but no data)",
      "immediate_fix": [
        "1. Check odds API status",
        "2. Check logs for error messages",
        "3. Retry manually",
        "4. Use different bookmaker API"
      ],
      "code_location": "src/discord_bot/prediction_generator.py - odds retry logic",
      "retry_logic": {
        "attempts": 8,
        "backoff": "exponential",
        "total_time": "8 minutes",
        "implemented": true
      }
    },
    
    "discord_posting_failure": {
      "symptoms": [
        "Prediction created but not posted",
        "Logs show prediction generated",
        "Database shows posted_to_discord = False",
        "No Discord message received"
      ],
      "root_cause": [
        "Invalid webhook URL",
        "Discord webhook deleted/expired",
        "Discord rate limiting",
        "Webhook permissions issue",
        "Network issues"
      ],
      "detection": "Watchdog: 'stale predictions (>4 hours old, not posted)'",
      "immediate_fix": [
        "1. Verify webhook URL in .env",
        "2. Test webhook manually:",
        "   curl -X POST -H 'Content-Type: application/json' -d '{\"content\": \"test\"}' <webhook_url>",
        "3. Check Discord server permissions",
        "4. Update webhook URL and restart"
      ],
      "code_location": "src/discord_bot/discord_bot.py"
    },
    
    "team_matching_failure": {
      "symptoms": [
        "Prediction missing teams",
        "'Team: None' in post",
        "Bets for wrong teams"
      ],
      "root_cause": [
        "Team tricodes don't match",
        "Team names don't match",
        "Nickname vs city name mismatch"
      ],
      "detection": "Visual inspection of Discord posts",
      "immediate_fix": [
        "1. Check team tricodes in database",
        "2. Check team tricodes from NBA CDN",
        "3. Update team mapping in code",
        "4. Use tricode-first matching (implemented)"
      ],
      "code_location": "src/discord_bot/prediction_generator.py - team matching",
      "current_logic": {
        "priority": ["Tricode", "City", "Name"],
        "tricodes": "BOS, LAL, GSW, etc.",
        "fallback": "Try city/name if tricode fails"
      }
    },
    
    "team_total_odds_flipped": {
      "symptoms": [
        "Team total bets assigned to wrong team",
        "Home team total shows as away team bet",
        "Away team total shows as home team bet",
        "Betting recommendations for team totals are incorrect"
      ],
      "root_cause": [
        "_format_bet_side() function uses incorrect fallback logic",
        "For team totals, bet.pick = 'OVER'/'UNDER' (not 'HOME'/'AWAY')",
        "Fallback condition 'bet.pick == \"HOME\"' always False",
        "Result: All team totals default to away_team"
      ],
      "detection": "Visual inspection of Discord posts showing wrong team for team total bets",
      "immediate_fix": [
        "1. Fixed in src/automation/post_generator.py",
        "2. Removed incorrect fallback logic for team totals",
        "3. Now trust bet.team_name which is set correctly in recommendations",
        "4. Added warning if bet.team_name is None"
      ],
      "code_location": "src/automation/post_generator.py - _format_bet_side()",
      "old_buggy_code": "team = bet.team_name or (home_team if bet.pick == 'HOME' else away_team)",
      "fixed_code": "if not bet.team_name: logger.warning(...); return f'{bet.team_name} {bet.pick} {bet.line}'",
      "fixed_date": "2026-02-26",
      "important_note": "Team total recommendations set team_name correctly during creation, but display logic was using wrong fallback"
    },
    
